---
import Layout from "@layouts/Layout.astro";

import TeamPage from "@components/Team.svelte";

const title = "Team";
const description =
  "Meet the DGRS Labs team, the AI storytelling platform behind CoNexus that grew out of the DeGenerous DAO community formed in early 2023.";
