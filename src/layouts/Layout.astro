---
import { SEO } from "astro-seo";
import { seoConfig } from "../../utils/seoConfig";

import "/src/styles/index.scss";

import Header from "@components/utils/Header.svelte";
import Footer from "@components/utils/Footer.svelte";

import Scramble from "@components/utils/Scramble.svelte";
import Background from "@components/utils/Background.svelte";
import Modal from "@components/utils/Modal.svelte";
import ToastContainer from "@components/utils/ToastContainer.svelte";
import Cursor from "@components/cursor/App.svelte";
import CookieBanner from "@components/utils/CookieBanner.svelte";

type LayoutProps = {
  nav?: string;
  title?: string;
  ogTitle?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  imageType?: string;
  type?: string;
  pageType?: string;
  structuredData?: Record<string, unknown>[];
  disableIndexing?: boolean;
  narrow?: boolean;
};

const {
  title,
  description,
  keywords,
  image = seoConfig.image.url,
  nav = "home",
  type = "website",
  pageType = "WebPage",
  structuredData = [],
  ogTitle,
  disableIndexing = false,
} = Astro.props as LayoutProps;

const defaultTitle = seoConfig.title;
const pageTitle = title?.trim();
const resolvedTitle = pageTitle
  ? pageTitle.includes("DGRS Labs")
    ? pageTitle
    : `${pageTitle} | DGRS Labs`
  : defaultTitle;
const resolvedOgTitle = ogTitle || resolvedTitle;
const resolvedDescription = description || seoConfig.description;
const resolvedImage = image.startsWith("http")
  ? image
  : new URL(image, `${seoConfig.baseURL}/`).toString();
const resolvedKeywords = keywords?.length ? keywords : seoConfig.keywords;

// Structured data for search engines and answer engines
const canonical = new URL(Astro.url?.pathname || "/", `${seoConfig.baseURL}/`).toString();
const orgId = `${seoConfig.baseURL}/#organization`;
const siteId = `${seoConfig.baseURL}/#website`;
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": orgId,
  url: seoConfig.baseURL,
  name: seoConfig.siteName,
  legalName: seoConfig.legalName,
  description: seoConfig.description,
  email: seoConfig.contactEmail,
  foundingDate: seoConfig.foundingDate,
  foundingLocation: {
    "@type": "Place",
    name: seoConfig.foundingLocation,
  },
  sameAs: seoConfig.sameAs,
  logo: {
    "@type": "ImageObject",
    url: seoConfig.image.url,
    width: seoConfig.image.width,
    height: seoConfig.image.height,
  },
  knowsAbout: [
    "AI storytelling",
    "interactive entertainment",
    "community-owned storytelling",
    "blockchain-backed IP",
    "creative tooling",
  ],
  contactPoint: [
    {
      "@type": "ContactPoint",
      email: seoConfig.contactEmail,
      contactType: "sales",
    },
  ],
};

const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": siteId,
  url: seoConfig.baseURL,
  name: seoConfig.siteName,
  description: seoConfig.description,
  inLanguage: (seoConfig.locale || "en_US").split("_")[0],
  publisher: {
    "@id": orgId,
  },
};

const pageLd = {
  "@context": "https://schema.org",
  "@type": pageType,
  url: canonical,
  name: resolvedTitle,
  description: resolvedDescription,
  isPartOf: {
    "@id": siteId,
  },
  about: {
    "@id": orgId,
  },
};
const jsonLdScripts = [orgLd, siteLd, pageLd, ...structuredData].map((item) =>
  JSON.stringify(item)
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://media.dgrslabs.ink" crossorigin />
    <!-- Performance hints: preconnect to third-parties used lazily -->
    <link rel="preconnect" href="https://platform.twitter.com" crossorigin />
    <link rel="preconnect" href="https://ton.twimg.com" crossorigin />
    <!-- Preload critical font weights to shorten font request chains -->
    <link rel="preload" as="font" href="/fonts/HankenGrotesk-Regular.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/HankenGrotesk-SemiBold.woff2" type="font/woff2" crossorigin />
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
    <meta name="author" content={seoConfig.legalName} />
    <meta name="keywords" content={resolvedKeywords.join(", ")} />
    <SEO
      title={resolvedTitle}
      description={resolvedDescription}
      canonical={canonical}
      noindex={disableIndexing}
      nofollow={disableIndexing}
      openGraph={{
        basic: {
          title: resolvedOgTitle,
          type,
          image: resolvedImage,
          url: canonical,
        },
        image: {
          width: seoConfig.image.width,
          height: seoConfig.image.height,
          alt: seoConfig.image.alt || resolvedTitle,
        },
        optional: {
          siteName: seoConfig.siteName,
          description: resolvedDescription,
        },
      }}
      twitter={{
        card: "summary_large_image",
      }}
    />
    {jsonLdScripts.map((content) => (
      <script is:inline type="application/ld+json" set:html={content} />
    ))}
  </head>

  <body class={nav}>
    <a href="#content" class="skip-link">Skip to content</a>
    <Scramble client:idle />
    <Header activeTab={nav} client:idle />
    <main id="content">
      <slot />
    </main>
    <Footer client:visible />
    <Background client:visible />
    <Modal client:idle />
    <ToastContainer client:idle />
    <!-- Defer heavy 3D cursor until visible to shorten critical chains -->
    <Cursor client:visible />
    <CookieBanner client:idle />
  </body>
</html>

